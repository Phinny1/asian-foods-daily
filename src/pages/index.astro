---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedRecipes from '../components/home/FeaturedRecipes.astro';
import CategoryGrid from '../components/home/CategoryGrid.astro';

const [recipes, blogPosts] = await Promise.all([
  getCollection('recipes', ({ data }) => data.draft !== true),
  getCollection('blog', ({ data }) => data.draft !== true),
]);

const entryMap = new Map<string, { entry: typeof recipes[number]; collection: string }>();
for (const entry of recipes) {
  entryMap.set(entry.slug, { entry, collection: 'recipes' });
}
for (const entry of blogPosts) {
  entryMap.set(entry.slug, { entry, collection: 'blog' });
}

function getEntry(slug: string) {
  const found = entryMap.get(slug);
  if (!found) return null;
  const { entry, collection } = found;
  return {
    title: entry.data.title,
    image: entry.data.image || '',
    href: `/${collection}/${entry.slug}/`,
  };
}

const weeknightDinners = [
  { slug: 'chicken-noodle-stir-fry-your-new-weeknight-hero', time: '20 Mins' },
  { slug: 'easy-30-minute-asian-chicken-meatballs', time: '30 Mins' },
  { slug: 'easy-homemade-chicken-satay', time: '25 Mins' },
  { slug: 'easy-ginger-scallion-noodles-recipe', time: '15 Mins' },
];

const chineseTakeout = [
  'chinese-eggplant-with-garlic-sauce',
  'bang-bang-chicken-skewers-recipe',
  'chicken-and-broccoli-chinese-takeout-style',
  'best-spicy-edamame-recipe',
];

const stirFry = [
  'easy-pepper-steak-stir-fry-recipe',
  'chicken-noodle-stir-fry-your-new-weeknight-hero',
  'chinese-tomato-egg-stir-fry',
  'easy-chinese-cabbage-stir-fry-recipe',
];

const noodlesRice = [
  'how-to-make-chicken-pad-thai-like-thai-street-vendors',
  'best-korean-beef-bulgogi-recipe',
  'chicken-katsu-curry-udon',
  'how-to-make-authentic-vietnamese-pho-at-home',
];

const soupsStews = [
  'how-to-make-the-best-cantonese-congee-ever',
  'regional-variations-of-ramen-across-asia',
  'is-pad-kra-pao-really-thailands-ultimate-street-food',
  'how-to-make-kimchi-jjigae-kimchi-stew',
];

const dimSum = [
  'how-to-make-perfect-soup-dumplings-xiaolongbao-at-home',
  'how-to-make-pork-and-shrimp-siu-mai',
  'how-to-make-pork-dumplings-at-home',
  'quick-chicken-buns-recipe',
];

const arrowIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;
---

<BaseLayout 
  title="Asian Foods Daily | Authentic Asian Recipes"
  description="Discover authentic Asian food recipes, step-by-step cooking guides, and delicious ideas for appetizers, noodles, soups, desserts & more."
  jsonLd={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://www.asianfoodsdaily.com/#organization",
        "name": "Asian Foods Daily",
        "url": "https://www.asianfoodsdaily.com/",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://www.asianfoodsdaily.com/#logo",
          "url": "https://www.asianfoodsdaily.com/logo.png",
          "width": 512,
          "height": 512
        },
        "sameAs": [
          "https://www.facebook.com/",
          "https://www.instagram.com/",
          "https://www.pinterest.com/"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://www.asianfoodsdaily.com/#website",
        "url": "https://www.asianfoodsdaily.com/",
        "name": "Asian Foods Daily",
        "publisher": {
          "@id": "https://www.asianfoodsdaily.com/#organization"
        },
        "inLanguage": "en-US",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://www.asianfoodsdaily.com/?s={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "WebPage",
        "@id": "https://www.asianfoodsdaily.com/#homepage",
        "url": "https://www.asianfoodsdaily.com/",
        "name": "Asian Foods Daily – Asian Recipes Made Simple",
        "description": "Asian Foods Daily brings you easy, authentic Asian recipes from across the continent — Thai, Chinese, Japanese, Korean, Vietnamese, Filipino, and more.",
        "isPartOf": {
          "@id": "https://www.asianfoodsdaily.com/#website"
        },
        "about": {
          "@id": "https://www.asianfoodsdaily.com/#organization"
        },
        "primaryImageOfPage": {
          "@id": "https://www.asianfoodsdaily.com/#logo"
        },
        "inLanguage": "en-US"
      },
      {
        "@type": "BreadcrumbList",
        "@id": "https://www.asianfoodsdaily.com/#breadcrumb",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://www.asianfoodsdaily.com/"
          }
        ]
      }
    ]
  }}
>
  <Hero />
  <FeaturedRecipes />
  <CategoryGrid />

  <section class="py-20 bg-zinc-50" data-ps="src/pages/index.astro:weeknight-dinners">
    <div class="container mx-auto px-4" data-ps="src/pages/index.astro:dinners-container">
      <div class="flex items-end justify-between mb-16 gap-6" data-ps="src/pages/index.astro:dinners-header">
        <div data-ps="src/pages/index.astro:dinners-titles">
          <h2 class="text-4xl font-bold text-zinc-900" data-ps="src/pages/index.astro:dinners-title">Easy Weeknight Dinners</h2>
        </div>
        <a href="/recipes/" class="inline-flex items-center gap-2 text-red-600 font-bold hover:gap-3 transition-all shrink-0" data-ps="src/pages/index.astro:dinners-more">
          View all recipes
          <Fragment set:html={arrowIcon} />
        </a>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8" data-ps="src/pages/index.astro:dinners-grid">
        {weeknightDinners.map((item, i) => {
          const recipe = getEntry(item.slug);
          if (!recipe) return null;
          return (
            <a href={recipe.href} class="group block bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-zinc-100" data-ps={`src/pages/index.astro:dinner-${i + 1}`}>
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={recipe.image}
                  alt={recipe.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy" />
              </div>
              <div class="p-4 md:p-8">
                <span class="inline-block px-3 py-1 bg-red-100 text-red-700 text-[10px] md:text-xs font-bold rounded-full mb-2 md:mb-4 uppercase tracking-wider">{item.time}</span>
                <h3 class="text-lg md:text-2xl font-bold text-zinc-900 group-hover:text-red-700 transition-colors line-clamp-2">{recipe.title}</h3>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {[
    { title: 'Chinese Takeout at Home', slugs: chineseTakeout, bg: 'bg-white', cardBg: 'bg-zinc-50', id: 'most-popular' },
    { title: 'Stir-Fry Recipes', slugs: stirFry, bg: 'bg-zinc-50', cardBg: 'bg-white', id: 'stir-fry-section' },
    { title: 'Noodles & Rice Bowls', slugs: noodlesRice, bg: 'bg-white border-b border-zinc-100', cardBg: 'bg-zinc-50', id: 'noodles-rice-section' },
    { title: 'Asian Soups & Stews', slugs: soupsStews, bg: 'bg-zinc-50 border-b border-zinc-100', cardBg: 'bg-white', id: 'soups-stews-section' },
    { title: 'Dim Sum & Dumplings', slugs: dimSum, bg: 'bg-white', cardBg: 'bg-zinc-50', id: 'dim-sum-section' },
  ].map((section) => (
    <section class={`py-20 ${section.bg}`} data-ps={`src/pages/index.astro:${section.id}`}>
      <div class="container mx-auto px-4">
        <div class="flex items-end justify-between mb-16 gap-6">
          <h2 class="text-4xl font-bold text-zinc-900">{section.title}</h2>
          <a href="/recipes/" class="inline-flex items-center gap-2 text-red-600 font-bold hover:gap-3 transition-all shrink-0">
            View all recipes
            <Fragment set:html={arrowIcon} />
          </a>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
          {section.slugs.map((slug, i) => {
            const recipe = getEntry(slug);
            if (!recipe) return null;
            return (
              <a href={recipe.href} class={`group block overflow-hidden rounded-2xl ${section.cardBg} border border-zinc-100 transition-all hover:shadow-xl hover:-translate-y-1`}>
                <div class="aspect-square overflow-hidden">
                  <img
                    src={recipe.image}
                    alt={recipe.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                    loading="lazy" />
                </div>
                <div class="p-4 md:p-6">
                  <h3 class="text-base md:text-xl font-bold text-zinc-900 leading-tight line-clamp-2">{recipe.title}</h3>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  ))}
  
  <section class="py-24 bg-red-600 text-white" data-ps="src/pages/index.astro:g2l9bz">
    <div class="container mx-auto px-4 text-center" data-ps="src/pages/index.astro:2b7xns">
      <h2 class="text-4xl font-bold mb-8" data-ps="src/pages/index.astro:frgy7m">Join Our Cooking Community</h2>
      <p class="text-white text-xl max-w-2xl mx-auto mb-12" data-ps="src/pages/index.astro:tff0kn">Get the latest recipes and cooking tips delivered straight to your inbox every week.</p>
      <form action="/subscribe/" method="POST" class="max-w-md mx-auto flex flex-col sm:flex-row gap-4">
        <input 
          type="email" 
          name="email"
          placeholder="your@email.com" 
          class="flex-1 px-6 py-4 rounded-xl bg-white text-zinc-900 focus:outline-none focus:ring-4 focus:ring-red-300 transition-all shadow-lg"
          required
        />
        <button type="submit" class="px-8 py-4 bg-zinc-900 text-white font-bold rounded-xl hover:bg-zinc-800 transition-all shadow-lg" data-ps="src/pages/index.astro:kfmv64">
          Subscribe
        </button>
      </form>

      {Astro.url.searchParams.get('subscribed') === '1' && (
        <div class="mt-8 p-4 bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl text-white inline-block animate-bounce" data-ps="src/pages/index.astro:2b7xns">
          <p class="font-bold flex items-center gap-2" data-ps="src/pages/index.astro:tff0kp">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Successfully subscribed!
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
