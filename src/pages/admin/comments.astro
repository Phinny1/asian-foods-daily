---
export const prerender = false;

import Layout from '../../layouts/BaseLayout.astro';

const runtime = Astro.locals.runtime;
if (!runtime?.env?.DB) {
  return new Response('Service unavailable', { status: 503 });
}

const db = runtime.env.DB;
const dashboardPassword = "AsianFoods2025";

// Simple session check via cookie
const authCookie = Astro.cookies.get('comment_admin_auth');
const isAuthenticated = authCookie?.value === dashboardPassword;

let error = '';
let success = '';

// Handle Actions (Approve, Delete, Login)
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'login') {
    const password = formData.get('password')?.toString()?.trim();
    if (password === dashboardPassword) {
      Astro.cookies.set('comment_admin_auth', dashboardPassword, { 
        path: '/', 
        httpOnly: true, 
        secure: true,
        sameSite: 'lax',
        maxAge: 60 * 60 * 24 * 7 // 1 week
      });
      return Astro.redirect(Astro.url.pathname);
    } else {
      error = 'Invalid password. Please check the spelling and try again.';
    }
  }

  if (isAuthenticated) {
    const commentId = formData.get('commentId')?.toString();

    try {
      if (action === 'approve') {
        await db.prepare('UPDATE comments SET is_approved = 1 WHERE id = ?').bind(commentId).run();
        success = 'Comment approved successfully';
      } else if (action === 'delete') {
        await db.prepare('DELETE FROM comments WHERE id = ?').bind(commentId).run();
        success = 'Comment deleted successfully';
      } else if (action === 'logout') {
        Astro.cookies.delete('comment_admin_auth', { path: '/' });
        return Astro.redirect(Astro.url.pathname);
      }
    } catch (e) {
      error = 'Database operation failed';
      console.error(e);
    }
  }
}

// Fetch comments
let pendingComments = [];
let approvedComments = [];

if (isAuthenticated) {
  try {
    const pendingRes = await db.prepare('SELECT * FROM comments WHERE is_approved = 0 ORDER BY created_at DESC').all();
    pendingComments = pendingRes.results;

    const approvedRes = await db.prepare('SELECT * FROM comments WHERE is_approved = 1 ORDER BY created_at DESC LIMIT 50').all();
    approvedComments = approvedRes.results;
  } catch (e) {
    console.error('Fetch error:', e);
  }
}
---

<Layout title="Comment Management Dashboard">
  <div class="max-w-6xl mx-auto px-4 py-12" data-ps="src/pages/admin/comments.astro:yowhg2">
    <div class="flex justify-between items-center mb-8" data-ps="src/pages/admin/comments.astro:yowhg3">
      <h1 class="text-3xl font-bold" data-ps="src/pages/admin/comments.astro:p4zxvd">Comment Management</h1>
      {isAuthenticated && (
        <form method="POST">
          <input type="hidden" name="action" value="logout" />
          <button type="submit" class="text-sm text-gray-600 hover:text-red-700" data-ps="src/pages/admin/comments.astro:13pg8f">Logout</button>
        </form>
      )}
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6" data-ps="src/pages/admin/comments.astro:yowhg4">
        {error}
      </div>
    )}

    {success && (
      <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6" data-ps="src/pages/admin/comments.astro:yowhg5">
        {success}
      </div>
    )}

    {!isAuthenticated ? (
      <div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow-sm border border-gray-100" data-ps="src/pages/admin/comments.astro:yowhg6">
        <h2 class="text-xl font-semibold mb-4 text-center" data-ps="src/pages/admin/comments.astro:v7p6vj">Admin Access</h2>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="login" />
          <div data-ps="src/pages/admin/comments.astro:yowhg7">
            <label class="block text-sm font-medium mb-1">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-red-500 outline-none" />
          </div>
          <button type="submit" class="w-full bg-red-700 text-white py-2 rounded-lg font-semibold hover:bg-red-800 transition" data-ps="src/pages/admin/comments.astro:13pg8g">
            Login
          </button>
        </form>
      </div>
    ) : (
      <div class="space-y-12" data-ps="src/pages/admin/comments.astro:5r6b8v">
        <!-- Pending Comments -->
        <section data-ps="src/pages/admin/comments.astro:s5l154">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2" data-ps="src/pages/admin/comments.astro:v7p6vk">
            <span class="w-3 h-3 bg-yellow-400 rounded-full" data-ps="src/pages/admin/comments.astro:z1ttx3"></span>
            Pending Approval ({pendingComments.length})
          </h2>
          {pendingComments.length === 0 ? (
            <p class="text-gray-600 italic" data-ps="src/pages/admin/comments.astro:nqp3bj">No pending comments.</p>
          ) : (
            <div class="grid gap-4" data-ps="src/pages/admin/comments.astro:5r6b8u">
              {pendingComments.map((comment) => (
                <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm" data-ps="src/pages/admin/comments.astro:5r6b8t">
                  <div class="flex justify-between items-start mb-4" data-ps="src/pages/admin/comments.astro:5r6b8s">
                    <div data-ps="src/pages/admin/comments.astro:5r6b8r">
                      <h3 class="font-bold text-lg" data-ps="src/pages/admin/comments.astro:gja9ny">{comment.username}</h3>
                      <p class="text-sm text-gray-600 font-medium" data-ps="src/pages/admin/comments.astro:nqp3bi">{comment.email}</p>
                      <p class="text-xs text-gray-500 mt-1" data-ps="src/pages/admin/comments.astro:t4v9x2">{new Date(comment.created_at).toLocaleString()}</p>
                      {comment.rating && (
                         <div class="flex text-yellow-800 mt-1" data-ps="src/pages/admin/comments.astro:5r6b8q">
                           {[...Array(5)].map((_, i) => (
                             <svg class={`w-4 h-4 ${i < comment.rating ? 'fill-current' : 'text-gray-300'}`} viewBox="0 0 20 20">
                               <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                             </svg>
                           ))}
                         </div>
                      )}
                    </div>
                    <div class="flex gap-2" data-ps="src/pages/admin/comments.astro:5r6b8p">
                      <form method="POST">
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="commentId" value={comment.id} />
                        <button type="submit" class="bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-green-800 transition" data-ps="src/pages/admin/comments.astro:13pg8h">Approve</button>
                      </form>
                      <form method="POST" onsubmit="return confirm('Are you sure you want to delete this comment?')">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="commentId" value={comment.id} />
                        <button type="submit" class="bg-white text-red-700 border border-red-200 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-50 transition" data-ps="src/pages/admin/comments.astro:13pg93">Delete</button>
                      </form>
                    </div>
                  </div>
                  <p class="text-gray-700 whitespace-pre-wrap" data-ps="src/pages/admin/comments.astro:nqp3bh">{comment.content}</p>
                </div>
              ))}
            </div>
          )}
        </section>

        <!-- Approved Comments -->
        <section data-ps="src/pages/admin/comments.astro:s5l153">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2" data-ps="src/pages/admin/comments.astro:v7p6w6">
            <span class="w-3 h-3 bg-green-500 rounded-full" data-ps="src/pages/admin/comments.astro:z1ttx2"></span>
            Recently Approved
          </h2>
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden" data-ps="src/pages/admin/comments.astro:5r6b8o">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-gray-50 border-bottom border-gray-200">
                  <th class="px-6 py-3 text-sm font-bold text-gray-600">Username</th>
                  <th class="px-6 py-3 text-sm font-bold text-gray-600">Email</th>
                  <th class="px-6 py-3 text-sm font-bold text-gray-600">Comment</th>
                  <th class="px-6 py-3 text-sm font-bold text-gray-600">Rating</th>
                  <th class="px-6 py-3 text-sm font-bold text-gray-600">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {approvedComments.map((comment) => (
                  <tr>
                    <td class="px-6 py-4">
                      <div class="font-semibold text-gray-900" data-ps="src/pages/admin/comments.astro:5r6b8n">{comment.username}</div>
                      <div class="text-xs text-gray-600 mt-1" data-ps="src/pages/admin/comments.astro:5r6b8l">{new Date(comment.created_at).toLocaleString()}</div>
                    </td>
                    <td class="px-6 py-4">
                      <div class="text-sm text-gray-600" data-ps="src/pages/admin/comments.astro:5r6b8m">{comment.email}</div>
                    </td>
                    <td class="px-6 py-4 text-sm text-gray-700 max-w-md">
                      <div class="line-clamp-3" data-ps="src/pages/admin/comments.astro:5r6b8m">{comment.content}</div>
                    </td>
                    <td class="px-6 py-4">
                      {comment.rating ? (
                        <div class="flex text-yellow-700" data-ps="src/pages/admin/comments.astro:5r6b8k">
                          {[...Array(5)].map((_, i) => (
                            <svg class={`w-3 h-3 ${i < comment.rating ? 'fill-current' : 'text-gray-200'}`} viewBox="0 0 20 20">
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                          ))}
                        </div>
                      ) : (
                        <span class="text-xs text-gray-600" data-ps="src/pages/admin/comments.astro:cl53lr">N/A</span>
                      )}
                    </td>
                    <td class="px-6 py-4">
                      <form method="POST" onsubmit="return confirm('Are you sure you want to delete this approved comment?')">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="commentId" value={comment.id} />
                        <button type="submit" class="text-red-700 hover:text-red-900 text-sm font-medium transition" data-ps="src/pages/admin/comments.astro:13pg94">Delete</button>
                      </form>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>
    )}
  </div>
</Layout>
