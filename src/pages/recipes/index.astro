---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const url = new URL(Astro.request.url);
const categoryFilter = url.searchParams.get('category');

const filterFn = (entry: any) => {
  const data = entry?.data;
  if (!data?.title) return false;
  if (data.draft === true) return false;

  if (categoryFilter) {
    const filter = categoryFilter.toLowerCase().trim();
    const category = (data.category || '').toLowerCase().trim();

    const normalize = (str: string) => {
      let s = str.toLowerCase().trim();
      if (s === 'rice') return s;
      return s.endsWith('s') ? s.slice(0, -1) : s;
    };

    const filterNorm = normalize(filter);
    const categoryNorm = normalize(category);

    return category === filter ||
           category.includes(filter) ||
           filter.includes(category) ||
           categoryNorm === filterNorm ||
           categoryNorm.includes(filterNorm) ||
           filterNorm.includes(categoryNorm);
  }

  return true;
};

// Fetch only from recipes collection
const recipes = await getCollection('recipes', filterFn);

const sortedRecipes = recipes.sort(
  (a, b) => (b.data?.pubDate?.valueOf() || 0) - (a.data?.pubDate?.valueOf() || 0)
);

const displayTitle = categoryFilter 
  ? `${categoryFilter.charAt(0).toUpperCase() + categoryFilter.slice(1).replace(/-/g, ' ')} Recipes`
  : 'Our Authentic Recipes';
---

<BaseLayout title="Recipes | Asian Foods Daily"
  description="Discover easy, authentic Asian recipes with step‑by‑step guides, bold flavors, and reliable cooking tips to elevate your home cooking every day"
  ogType="website"
  noIndex={false}>
  <main class="bg-zinc-50 min-h-screen" data-ps="src/pages/recipes/index.astro:ev2cet">
    <!-- Hero Section -->
    <section class="bg-zinc-900 py-24 px-4 overflow-hidden relative" data-ps="src/pages/recipes/index.astro:mxwryf">
      <div class="absolute inset-0 opacity-20" data-ps="src/pages/recipes/index.astro:776adu">
        <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1664337873053-840ea51d271d?auto=format&w=1920&q=80" 
          alt="Asian Food background" 
          class="w-full h-full object-cover" data-ps="src/pages/recipes/index.astro:7ktnls"
        />
      </div>
      <div class="container mx-auto relative z-10 text-center" data-ps="src/pages/recipes/index.astro:776adt">
        <h1 class="text-5xl md:text-7xl font-black text-white mb-6 tracking-tighter" data-ps="src/pages/recipes/index.astro:itb2vm">{displayTitle.split(' ').slice(0, -1).join(' ')} <span class="text-red-500" data-ps="src/pages/recipes/index.astro:sddxd4">{displayTitle.split(' ').pop()}</span></h1>
        <p class="text-zinc-400 text-xl max-w-2xl mx-auto font-medium" data-ps="src/pages/recipes/index.astro:go9kyz">Explore our collection of authentic Asian dishes, from street food favorites to family classics.</p>
      </div>
    </section>

    <!-- Recipe Grid -->
    <section class="py-20 px-4" data-ps="src/pages/recipes/index.astro:mxwrye">
      <div class="container mx-auto" data-ps="src/pages/recipes/index.astro:776ads">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" data-ps="src/pages/recipes/index.astro:776adr">
          {sortedRecipes.map((recipe) => (
            <a href={`/recipes/${recipe.slug}/`} class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col" data-ps="src/pages/recipes/index.astro:9kbo9v">
              <div class="aspect-[4/3] overflow-hidden relative" data-ps="src/pages/recipes/index.astro:776adq">
                <img 
                  src={recipe.data.image || "https://images.unsplash.com/photo-1651836170595-4b0e7cba3952?auto=format&w=800&q=80"} 
                  alt={recipe.data.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" data-ps="src/pages/recipes/index.astro:7ktnlr"
                />
                <div class="absolute top-4 left-4 bg-red-600 text-white text-xs font-black uppercase tracking-widest px-4 py-2 rounded-full" data-ps="src/pages/recipes/index.astro:776adp">
                  {recipe.data.category || 'Recipe'}
                </div>
              </div>
              <div class="p-8 flex-grow flex flex-col" data-ps="src/pages/recipes/index.astro:776ado">
                <div class="flex items-center gap-2 text-zinc-400 text-xs font-bold uppercase tracking-widest mb-4" data-ps="src/pages/recipes/index.astro:776adn">
                  <span data-ps="src/pages/recipes/index.astro:sddxd5">{recipe.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                </div>
                <h2 class="text-2xl font-black text-zinc-900 group-hover:text-red-600 transition-colors mb-4 line-clamp-2" data-ps="src/pages/recipes/index.astro:44w5o1">{recipe.data.title}</h2>
                <p class="text-zinc-600 font-medium mb-8 line-clamp-3" data-ps="src/pages/recipes/index.astro:go9kz0">{recipe.data.description}</p>
                <div class="mt-auto flex items-center justify-between" data-ps="src/pages/recipes/index.astro:776adm">
                  <span class="text-zinc-900 font-black text-sm uppercase tracking-tighter group-hover:translate-x-2 transition-transform duration-300" data-ps="src/pages/recipes/index.astro:sddxd6">View Recipe →</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        {sortedRecipes.length === 0 && (
          <div class="text-center py-20 bg-white rounded-3xl border-2 border-dashed border-zinc-200" data-ps="src/pages/recipes/index.astro:776adl">
            <h3 class="text-2xl font-bold text-zinc-400" data-ps="src/pages/recipes/index.astro:ajirjk">Coming soon! We're preparing our best recipes for you.</h3>
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
