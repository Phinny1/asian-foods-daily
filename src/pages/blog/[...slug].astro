---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const filterFn = ({ data }: { data: any }) => data.draft !== true;

  const blogEntries = await getCollection('blog', filterFn);

  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, collectionName: 'blog' },
  }));
}

const { entry, collectionName } = Astro.props;
const { Content, headings } = await entry.render();
const mdxFilePath = `src/content/${collectionName}/${entry.slug}.mdx`;
---

<BlogLayout frontmatter={entry.data} mdxFilePath={mdxFilePath} headings={headings}>
  <Content />
</BlogLayout>
