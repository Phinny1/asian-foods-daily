---
import { siteConfig } from '../config/site';
import { getCollection } from 'astro:content';
import SearchOverlay from './islands/SearchOverlay';

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Recipes', href: '/recipes/' },
  { name: 'Blog', href: '/blog/' },
  { name: 'About', href: '/about/' }
];

const cuisines = [
  { name: 'Chinese', href: '/cuisines/chinese/', icon: '🇨🇳' },
  { name: 'Japanese', href: '/cuisines/japanese/', icon: '🇯🇵' },
  { name: 'Korean', href: '/cuisines/korean/', icon: '🇰🇷' },
  { name: 'Filipino', href: '/cuisines/filipino/', icon: '🇵🇭' },
  { name: 'Vietnamese', href: '/cuisines/vietnamese/', icon: '🇻🇳' },
  { name: 'Thai', href: '/cuisines/thai/', icon: '🇹🇭' },
  { name: 'Indian', href: '/cuisines/indian/', icon: '🇮🇳' }
];

const blogPosts = await getCollection('blog', (entry) => {
  return entry?.data?.draft !== true && entry?.data?.title;
});

const recipePosts = await getCollection('recipes', (entry) => {
  return entry?.data?.draft !== true && entry?.data?.title;
});

// Combine and map to simple objects
const posts = [
  ...blogPosts.map(post => ({
    slug: post.slug,
    collection: 'blog',
    data: {
      title: post.data.title || '',
      description: post.data.description || '',
      image: post.data.image || '',
      category: post.data.category || 'Blog',
    }
  })),
  ...recipePosts.map(post => ({
    slug: post.slug,
    collection: 'recipes',
    data: {
      title: post.data.title || '',
      description: post.data.description || '',
      image: post.data.image || '',
      category: post.data.category || 'Recipe',
    }
  }))
];
---

<nav id="main-nav" class="sticky top-0 z-50 transition-all duration-300 bg-white/90 backdrop-blur-lg border-b border-zinc-100" data-ps="src/components/Navigation.astro:m59h3c">
  <div class="container mx-auto px-4" data-ps="src/components/Navigation.astro:gqvsde">
    <div class="flex items-center justify-between h-20 md:h-24" data-ps="src/components/Navigation.astro:gqvsdd">
      <a href="/" class="flex items-center group" data-ps="src/components/Navigation.astro:7vkjsf">
        <span class="text-2xl font-black text-zinc-900 tracking-tighter" data-ps="src/components/Navigation.astro:i2om6a">AsianFoods<span class="text-red-600" data-ps="src/components/Navigation.astro:i2om69">Daily</span></span>
      </a>

      <div class="hidden lg:flex items-center gap-10" data-ps="src/components/Navigation.astro:gqvsdb">
        <a href="/" class="text-zinc-600 hover:text-red-600 font-bold tracking-tight transition-colors text-sm uppercase" data-ps="src/components/Navigation.astro:kd8n5y">Home</a>
        <a href="/recipes/" class="text-zinc-600 hover:text-red-600 font-bold tracking-tight transition-colors text-sm uppercase" data-ps="src/components/Navigation.astro:kd8n5z">Recipes</a>
        
        {/* Cuisines Dropdown */}
        <div class="relative group/dropdown" data-ps="src/components/Navigation.astro:gqvsde">
          <button class="flex items-center gap-1 text-zinc-600 group-hover/dropdown:text-red-600 font-bold tracking-tight transition-colors text-sm uppercase cursor-pointer" data-ps="src/components/Navigation.astro:4mva7">
            Cuisines
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/dropdown:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          
          <div class="absolute top-full -left-4 w-56 pt-6 opacity-0 translate-y-2 pointer-events-none group-hover/dropdown:opacity-100 group-hover/dropdown:translate-y-0 group-hover/dropdown:pointer-events-auto transition-all duration-300" data-ps="src/components/Navigation.astro:gqvsdd">
            <div class="bg-white border border-zinc-100 shadow-2xl rounded-2xl p-2 overflow-hidden" data-ps="src/components/Navigation.astro:gqvsdc">
              {cuisines.map((cuisine) => (
                <a 
                  href={cuisine.href} 
                  class="flex items-center gap-3 px-4 py-3 text-sm font-bold text-zinc-600 hover:text-red-600 hover:bg-zinc-50 rounded-xl transition-all"
                 data-ps="src/components/Navigation.astro:7vkjsf">
                  <span class="text-xl" data-ps="src/components/Navigation.astro:i2om6d">{cuisine.icon}</span>
                  {cuisine.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href="/blog/" class="text-zinc-600 hover:text-red-600 font-bold tracking-tight transition-colors text-sm uppercase" data-ps="src/components/Navigation.astro:7vkjse">Blog</a>
        <a href="/about/" class="text-zinc-600 hover:text-red-600 font-bold tracking-tight transition-colors text-sm uppercase" data-ps="src/components/Navigation.astro:7vkjsd">About</a>

        <button id="search-btn-desktop" class="hidden lg:flex items-center gap-3 px-4 py-2.5 bg-zinc-100 hover:bg-zinc-200 rounded-full transition-colors group text-left w-64" aria-label="Search" data-ps="src/components/Navigation.astro:4mvac">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-red-600 transition-colors"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span class="text-zinc-500 font-medium text-sm group-hover:text-zinc-700" data-ps="src/components/Navigation.astro:i2om6i">Search recipes...</span>
          <span class="ml-auto text-xs text-zinc-400 font-bold border border-zinc-300 rounded px-1.5 py-0.5" data-ps="src/components/Navigation.astro:i2om6h">⌘K</span>
        </button>
      </div>

      <button id="mobile-menu-btn" class="lg:hidden p-2 text-zinc-900 focus:outline-none" data-ps="src/components/Navigation.astro:4mvab">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-zinc-100 h-[calc(100vh-80px)] overflow-y-auto py-8 px-6 absolute top-full left-0 w-full shadow-2xl animate-fade-in-down" data-ps="src/components/Navigation.astro:gqvsda">
    <div class="flex flex-col gap-8" data-ps="src/components/Navigation.astro:gqvsd9">
      <a href="/" class="text-3xl font-black text-zinc-900 hover:text-red-600 transition-colors" data-ps="src/components/Navigation.astro:7vkjsc">Home</a>
      <a href="/recipes/" class="text-3xl font-black text-zinc-900 hover:text-red-600 transition-colors" data-ps="src/components/Navigation.astro:7vkjsb">Recipes</a>
      
      <div class="flex flex-col gap-6" data-ps="src/components/Navigation.astro:gqvsdb">
        <span class="text-3xl font-black text-zinc-900" data-ps="src/components/Navigation.astro:i2om6c">Cuisines</span>
        <div class="grid grid-cols-2 gap-4" data-ps="src/components/Navigation.astro:gqvsda">
          {cuisines.map((cuisine) => (
            <a 
              href={cuisine.href} 
              class="flex items-center gap-3 p-4 bg-zinc-50 rounded-2xl text-lg font-bold text-zinc-900 hover:bg-red-50 hover:text-red-600 transition-all"
             data-ps="src/components/Navigation.astro:7vkjsa">
              <span data-ps="src/components/Navigation.astro:i2om6b">{cuisine.icon}</span>
              {cuisine.name}
            </a>
          ))}
        </div>
      </div>

      <a href="/blog/" class="text-3xl font-black text-zinc-900 hover:text-red-600 transition-colors" data-ps="src/components/Navigation.astro:7vkjs9">Blog</a>
      <a href="/about/" class="text-3xl font-black text-zinc-900 hover:text-red-600 transition-colors" data-ps="src/components/Navigation.astro:7vkjs8">About</a>

      <button id="search-btn-mobile" class="mt-4 flex items-center justify-between bg-zinc-900 text-white px-8 py-5 rounded-2xl font-bold text-xl" data-ps="src/components/Navigation.astro:4mvaa">
        <span data-ps="src/components/Navigation.astro:i2om6i">Search</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
    </div>
  </div>
  <!-- Search Overlay -->
  <SearchOverlay client:load posts={posts} />
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const searchBtnDesktop = document.getElementById('search-btn-desktop');
  const searchBtnMobile = document.getElementById('search-btn-mobile');

  function openSearch() {
    window.dispatchEvent(new CustomEvent('open-search'));
  }

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  searchBtnDesktop?.addEventListener('click', openSearch);
  searchBtnMobile?.addEventListener('click', () => {
    mobileMenu?.classList.add('hidden');
    openSearch();
  });

  // Add keyboard shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });

  // Handle nav background on scroll
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('main-nav');
    if (window.scrollY > 20) {
      nav?.classList.add('shadow-xl', 'h-20');
      nav?.classList.remove('h-24');
    } else {
      nav?.classList.remove('shadow-xl', 'h-20');
      nav?.classList.add('h-24');
    }
  });
</script>

<style is:global>
  @keyframes fade-in-down {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-down {
    animation: fade-in-down 0.3s ease-out;
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .animate-fade-in {
    animation: fade-in 0.2s ease-out;
  }
</style>
