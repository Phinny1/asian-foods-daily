---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
}

const { headings, title = 'Table of Contents' } = Astro.props;

// Filter to h2 and h3 only (h1 is the page title, h4+ too granular)
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 2 && (
  <nav class="toc not-prose mb-8 rounded-xl border border-gray-100 bg-gray-50 p-6" data-ps="src/components/TableOfContents.astro:nav">
    <p class="mb-4 text-lg font-black text-zinc-900" data-ps="src/components/TableOfContents.astro:title">{title}</p>
    <ul class="space-y-2 text-sm" data-ps="src/components/TableOfContents.astro:list">
      {tocHeadings.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-4' : ''} data-ps="src/components/TableOfContents.astro:item">
          <a
            href={`#${heading.slug}`}
            class={`block py-1 transition-colors hover:text-cyan-700 hover:underline ${heading.depth === 2 ? 'font-semibold text-gray-800' : 'text-gray-600'}`}
            data-ps="src/components/TableOfContents.astro:link"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
