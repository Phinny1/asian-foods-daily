---
const { slug } = Astro.props;
---

<div class="mt-16 pt-8 border-t border-gray-200" data-ps="src/components/Comments.astro:mxodmm">
  <h2 class="text-2xl font-bold mb-8 text-gray-900" data-ps="src/components/Comments.astro:wy8hb9">Post your Comment</h2>

  <form id="comment-form" class="space-y-6 bg-gray-50 p-6 rounded-2xl border border-gray-100 mb-12">
    <input type="hidden" name="slug" value={slug} />
    <input type="hidden" name="captchaAnswer" id="captcha-answer" value="" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/Comments.astro:mxodmo">
      <div data-ps="src/components/Comments.astro:mxodmp">
        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
        <input type="text" name="username" id="username" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none" placeholder="Your name" />
      </div>
      <div data-ps="src/components/Comments.astro:mxodmq">
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email (not published)</label>
        <input type="email" name="email" id="email" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none" placeholder="your@email.com" />
      </div>
    </div>

    <div data-ps="src/components/Comments.astro:mxodmr">
      <label class="block text-sm font-medium text-gray-700 mb-2">Your Rating</label>
      <div class="flex gap-2" id="star-rating" data-ps="src/components/Comments.astro:mxodms">
        {[1, 2, 3, 4, 5].map((num) => (
          <button type="button" data-rating={num} class="star-btn text-2xl text-gray-600 hover:text-yellow-400 transition-colors" data-ps="src/components/Comments.astro:aaev44">★</button>
        ))}
        <input type="hidden" name="rating" id="rating-input" value="0" />
      </div>
    </div>

    <div data-ps="src/components/Comments.astro:mxodmt">
      <label for="content" class="block text-sm font-medium text-gray-700 mb-1">Comment</label>
      <textarea name="content" id="content" rows="4" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none" placeholder="Share your thoughts or recipe tips..."></textarea>
    </div>

    <div class="flex flex-col md:flex-row md:items-end gap-6" data-ps="src/components/Comments.astro:mxodmu">
      <div class="w-64" data-ps="src/components/Comments.astro:mxodmv">
        <label for="captcha" class="block text-sm font-medium text-gray-700 mb-1">Security Code</label>
        <div class="flex items-center gap-3 mb-2 bg-white p-2 rounded border border-gray-200 select-none" data-ps="src/components/Comments.astro:mxodmn">
          <div id="captcha-display" class="font-mono text-xl font-bold tracking-[0.3em] text-red-700 bg-red-50 px-3 py-1 rounded italic line-through decoration-gray-400 decoration-1 select-none pointer-events-none" data-ps="src/components/Comments.astro:mxodmm">
            <!-- Generated via JS -->
          </div>
          <button type="button" id="refresh-captcha" class="p-1 text-gray-600 hover:text-red-700 transition-colors" title="Refresh code" data-ps="src/components/Comments.astro:77et2g">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
          </button>
        </div>
        <input type="text" name="captcha" id="captcha" required class="w-full px-4 py-2 rounded-lg border border-gray-300 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none uppercase" placeholder="Enter code" />
      </div>
      <button type="submit" class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg transition-all shadow-lg shadow-red-200 active:scale-95 h-[42px] mb-[2px]" data-ps="src/components/Comments.astro:aaev43">
        Submit Comment
      </button>
    </div>
  </form>

  <div id="comments-section" class="space-y-8" data-ps="src/components/Comments.astro:ov6s1">
    <h3 id="comments-count" class="text-xl font-bold text-gray-900 border-b border-gray-100 pb-4" data-ps="src/components/Comments.astro:i9tk3o">Loading comments...</h3>
    <div id="comments-list" class="space-y-8" data-ps="src/components/Comments.astro:ov6s2"></div>
  </div>
</div>

<script>
  const form = document.getElementById('comment-form') as HTMLFormElement;
  const ratingBtns = document.querySelectorAll('.star-btn');
  const ratingInput = document.getElementById('rating-input') as HTMLInputElement;
  const commentsCount = document.getElementById('comments-count');
  const commentsList = document.getElementById('comments-list');
  const captchaDisplay = document.getElementById('captcha-display');
  const captchaAnswerInput = document.getElementById('captcha-answer') as HTMLInputElement;
  const refreshCaptchaBtn = document.getElementById('refresh-captcha');

  const CAPTCHA_CHARS = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';

  function generateCaptchaCode() {
    let code = '';
    for (let i = 0; i < 6; i++) {
      code += CAPTCHA_CHARS.charAt(Math.floor(Math.random() * CAPTCHA_CHARS.length));
    }
    return { code, answer: code };
  }

  function refreshMainCaptcha() {
    const { code, answer } = generateCaptchaCode();
    if (captchaDisplay) captchaDisplay.textContent = code;
    if (captchaAnswerInput) captchaAnswerInput.value = answer;
  }

  refreshMainCaptcha();
  refreshCaptchaBtn?.addEventListener('click', refreshMainCaptcha);

  const slugInput = form?.querySelector('input[name="slug"]') as HTMLInputElement;
  const postSlug = slugInput?.value || '';

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function removeInlineReplyForm() {
    document.querySelector('.inline-reply-form')?.remove();
  }

  function showInlineReplyForm(commentId: string, username: string, replyBtn: Element) {
    removeInlineReplyForm();

    const captcha = generateCaptchaCode();
    const wrapper = document.createElement('div');
    wrapper.className = 'inline-reply-form mt-4 p-5 bg-white rounded-xl border-2 border-red-50 shadow-sm';
    wrapper.innerHTML = `
      <div class="flex items-center justify-between mb-4">
        <span class="text-sm font-medium text-gray-700">Replying to <span class="text-red-600 font-bold">${escapeHtml(username)}</span></span>
        <button type="button" class="inline-reply-cancel text-xs font-semibold text-gray-400 hover:text-gray-600 uppercase tracking-wider">Cancel</button>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1 ml-1">Name</label>
          <input type="text" name="reply-username" required class="w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none" placeholder="Your name" />
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1 ml-1">Email (not published)</label>
          <input type="email" name="reply-email" required class="w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none" placeholder="your@email.com" />
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1 ml-1">Your Rating</label>
        <div class="flex gap-1.5" id="reply-star-rating">
          ${[1, 2, 3, 4, 5].map((num) => `
            <button type="button" data-rating="${num}" class="reply-star-btn text-xl text-gray-300 hover:text-yellow-400 transition-colors">★</button>
          `).join('')}
          <input type="hidden" name="reply-rating" value="0" />
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1 ml-1">Reply Content</label>
        <textarea name="reply-content" rows="3" required class="w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none" placeholder="Write your reply..."></textarea>
      </div>
      <div class="flex flex-col md:flex-row items-stretch md:items-end gap-4">
        <div class="flex-1 max-w-xs">
          <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1 ml-1">Security Verification</label>
          <div class="flex items-center gap-2 mb-2 bg-gray-50 p-2 rounded border border-gray-100">
            <div class="inline-captcha-display font-mono text-base font-bold tracking-[0.2em] text-red-700 select-none">${captcha.code}</div>
            <button type="button" class="inline-captcha-refresh p-1 text-gray-400 hover:text-red-600 transition-colors" title="Refresh code">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
            </button>
          </div>
          <input type="text" name="reply-captcha" required class="w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none uppercase" placeholder="Enter code" />
        </div>
        <button type="button" class="inline-reply-submit bg-red-600 hover:bg-red-700 text-white font-bold py-2.5 px-6 text-sm rounded-lg transition-all active:scale-95 shadow-lg shadow-red-100">
          Post Reply
        </button>
      </div>
    `;

    // Ensure we insert it after the reply button or the main comment container
    const insertionPoint = replyBtn;
    insertionPoint.insertAdjacentElement('afterend', wrapper);

    (wrapper.querySelector('input[name="reply-username"]') as HTMLInputElement)?.focus();

    let currentCaptcha = captcha;

    wrapper.querySelector('.inline-captcha-refresh')?.addEventListener('click', () => {
      currentCaptcha = generateCaptchaCode();
      const display = wrapper.querySelector('.inline-captcha-display');
      if (display) display.textContent = currentCaptcha.code;
    });

    wrapper.querySelector('.inline-reply-cancel')?.addEventListener('click', removeInlineReplyForm);

    const replyRatingBtns = wrapper.querySelectorAll('.reply-star-btn');
    const replyRatingInput = wrapper.querySelector('input[name="reply-rating"]') as HTMLInputElement;

    replyRatingBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const rating = btn.getAttribute('data-rating') || '0';
        replyRatingInput.value = rating;
        replyRatingBtns.forEach(b => {
          const bRating = b.getAttribute('data-rating') || '0';
          if (parseInt(bRating) <= parseInt(rating)) {
            b.classList.add('text-yellow-400');
            b.classList.remove('text-gray-300');
          } else {
            b.classList.remove('text-yellow-400');
            b.classList.add('text-gray-300');
          }
        });
      });
    });

    wrapper.querySelector('.inline-reply-submit')?.addEventListener('click', async () => {
      const replyUsername = (wrapper.querySelector('input[name="reply-username"]') as HTMLInputElement).value.trim();
      const replyEmail = (wrapper.querySelector('input[name="reply-email"]') as HTMLInputElement).value.trim();
      const replyContent = (wrapper.querySelector('textarea[name="reply-content"]') as HTMLTextAreaElement).value.trim();
      const replyCaptchaInput = (wrapper.querySelector('input[name="reply-captcha"]') as HTMLInputElement).value.trim().toUpperCase();
      const replyRating = replyRatingInput.value;

      if (!replyUsername || !replyEmail || !replyContent) {
        alert('Please fill in all fields.');
        return;
      }

      const submitBtn = wrapper.querySelector('.inline-reply-submit') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Posting...';

      const formData = new FormData();
      formData.append('slug', postSlug);
      formData.append('username', replyUsername);
      formData.append('email', replyEmail);
      formData.append('content', replyContent);
      formData.append('rating', replyRating);
      formData.append('parentId', commentId);
      formData.append('captcha', replyCaptchaInput);
      formData.append('captchaAnswer', currentCaptcha.answer);

      try {
        const response = await fetch('/api/comments/', {
          method: 'POST',
          body: formData,
        });

        const contentType = response.headers.get('content-type');
        let result;
        if (contentType && contentType.includes('application/json')) {
          result = await response.json();
        } else {
          throw new Error('Server returned an unexpected response format');
        }

        if (response.ok) {
          removeInlineReplyForm();
          alert('Reply submitted! It will appear after approval.');
          loadComments();
        } else {
          currentCaptcha = generateCaptchaCode();
          const display = wrapper.querySelector('.inline-captcha-display');
          if (display) display.textContent = currentCaptcha.code;
          alert(result.error || 'Something went wrong.');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Post Reply';
        }
      } catch (error) {
        console.error('Reply submission error:', error);
        alert(error instanceof Error ? error.message : 'Failed to post reply.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Post Reply';
      }
    });
  }

  function bindReplyButtons() {
    document.querySelectorAll('.reply-btn').forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        const id = btn.getAttribute('data-id') || '';
        const username = btn.getAttribute('data-username') || '';
        showInlineReplyForm(id, username, btn);
      };
    });
  }

  async function loadComments() {
    if (!postSlug) return;
    try {
      const res = await fetch(`/api/comments/?slug=${encodeURIComponent(postSlug)}`);
      const { comments = [] } = await res.json();

      const mainComments = comments.filter((c: any) => !c.parent_id);
      const replies = comments.filter((c: any) => c.parent_id);

      if (commentsCount) {
        commentsCount.textContent = `${comments.length} Comment${comments.length !== 1 ? 's' : ''}`;
      }

      if (!commentsList) return;

      if (mainComments.length === 0) {
        commentsList.innerHTML = '<p class="text-gray-600 italic">No comments yet. Be the first to share your thoughts!</p>';
        return;
      }

      commentsList.innerHTML = mainComments.map((comment: any) => {
        const commentReplies = replies.filter((r: any) => r.parent_id === comment.id);
        const stars = comment.rating
          ? `<div class="flex gap-1 mb-2">${[...Array(5)].map((_, i) =>
              `<span class="${i < comment.rating ? 'text-yellow-400 text-sm' : 'text-gray-200 text-sm'}">★</span>`
            ).join('')}</div>`
          : '';

        const repliesHtml = commentReplies.length > 0
          ? `<div class="mt-6 ml-4 pl-4 border-l-2 border-gray-100 space-y-6">
              ${commentReplies.map((reply: any) => {
                const replyStars = reply.rating
                  ? `<div class="flex gap-1 mb-1">${[...Array(5)].map((_, i) =>
                      `<span class="${i < reply.rating ? 'text-yellow-400 text-[10px]' : 'text-gray-200 text-[10px]'}">★</span>`
                    ).join('')}</div>`
                  : '';
                return `
                  <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 text-xs font-bold shrink-0">
                      ${reply.username.charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="font-bold text-gray-800 text-sm">${escapeHtml(reply.username)}</span>
                        <span class="text-[10px] text-gray-600">${new Date(reply.created_at).toLocaleDateString()}</span>
                      </div>
                      ${replyStars}
                      <p class="text-gray-600 text-sm leading-relaxed">${escapeHtml(reply.content)}</p>
                    </div>
                  </div>
                `;
              }).join('')}
            </div>`
          : '';

        return `
          <div class="group bg-white p-4 rounded-xl transition-all hover:shadow-sm">
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-red-700 font-bold shrink-0">
                ${comment.username.charAt(0).toUpperCase()}
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between mb-1">
                  <span class="font-bold text-gray-900">${escapeHtml(comment.username)}</span>
                  <span class="text-xs text-gray-600">${new Date(comment.created_at).toLocaleDateString()}</span>
                </div>
                ${stars}
                <p class="text-gray-700 leading-relaxed mb-3">${escapeHtml(comment.content)}</p>
                <button type="button" class="reply-btn text-sm font-bold text-red-600 hover:text-red-700 flex items-center gap-1.5 transition-colors"
                  data-id="${comment.id}" data-username="${escapeHtml(comment.username)}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17l-5-5 5-5M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
                  Reply
                </button>
                ${repliesHtml}
              </div>
            </div>
          </div>
        `;
      }).join('');

      bindReplyButtons();
    } catch (e) {
      console.warn('Failed to load comments:', e);
    }
  }

  if (ratingBtns) {
    ratingBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const rating = btn.getAttribute('data-rating');
        if (ratingInput) ratingInput.value = rating || '0';

        ratingBtns.forEach(b => {
          const bRating = b.getAttribute('data-rating');
          const currentRating = parseInt(rating || '0');
          const buttonRating = parseInt(bRating || '0');

          if (buttonRating <= currentRating) {
            b.classList.add('text-yellow-400');
            b.classList.remove('text-gray-600');
          } else {
            b.classList.remove('text-yellow-400');
            b.classList.add('text-gray-600');
          }
        });
      });
    });
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalBtnText = submitBtn.textContent;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData();
    const elements = form.elements as any;

    formData.append('slug', elements.slug.value);
    formData.append('username', elements.username.value);
    formData.append('email', elements.email.value);
    formData.append('content', elements.content.value);
    formData.append('rating', elements.rating.value || '0');
    formData.append('parentId', '');
    formData.append('captcha', elements.captcha.value.toUpperCase());
    formData.append('captchaAnswer', elements.captchaAnswer.value);

    try {
      const response = await fetch('/api/comments/', {
        method: 'POST',
        body: formData,
      });

      let result;
      const contentType = response.headers.get('content-type');
      if (contentType && contentType.includes('application/json')) {
        result = await response.json();
      } else {
        throw new Error('Server error');
      }

      if (response.ok) {
        alert('Comment submitted! It will appear after approval.');
        form.reset();
        ratingBtns.forEach(b => {
          b.classList.remove('text-yellow-400');
          b.classList.add('text-gray-600');
        });
        refreshMainCaptcha();
        loadComments();
      } else {
        refreshMainCaptcha();
        alert(result.error || 'Error saving comment.');
      }
    } catch (error) {
      alert('Failed to post comment.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
    }
  });

  loadComments();
</script>
