---
// SEO Head component - shared across all layouts
// Import inside <head> tag, outputs meta tags (no wrapper)

import { siteConfig as SITE } from '../config/site';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  publishedTime?: string;
  jsonLd?: Record<string, any>;
}

const {
  title = SITE.title,
  description = SITE.description,
  image,
  type = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

// Environment variables for auto-generated OG images
const ACCOUNT_ID = import.meta.env.ACCOUNT_ID || '';
const SITE_ID = import.meta.env.SITE_ID || '';
const OG_IMAGE_CDN_URL = import.meta.env.OG_IMAGE_CDN_URL || 'https://cdn.pagesmith.app';

// Auto-generate OG image URL
const pathname = Astro.url.pathname;
const slug = pathname === '/' ? 'index' : pathname.replace(/^\/|\/$/g, '');

const autoImage = (ACCOUNT_ID && SITE_ID)
  ? `${OG_IMAGE_CDN_URL}/${ACCOUNT_ID}/${SITE_ID}/${slug}-og.png`
  : (SITE.brand?.logo || `/${slug === 'index' ? 'home' : slug.split('/')[0]}-og.jpg`);
const finalImage = image || autoImage;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);
const ogImageURL = finalImage.startsWith('http') ? finalImage : new URL(finalImage, SITE.url).toString();

// Cast SITE to any to access properties that might not be in the type definition yet
const twitterHandle = (SITE as any).twitterHandle || '';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />
<meta name="google-site-verification" content="npFHT7SNH7ie8i7fzKyV0-6X94W9dH6nsnh_0k296C8" />
<meta name="description" content={description} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:site_name" content={SITE.title} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={title} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
{twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Page Title -->
<title>{title}</title>

<!-- Pinterest Save Button -->
<script
  is:inline
  async
  defer
  data-pin-hover="true"
  data-pin-tall="true"
  src="//assets.pinterest.com/js/pinit.js"
></script>

<!-- Structured Data / JSON-LD -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
