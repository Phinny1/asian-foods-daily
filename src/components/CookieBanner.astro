---
import { siteConfig } from '../config/site';

const primaryColor = siteConfig.brand.colors.primary;
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[100] transform translate-y-full transition-transform duration-500 ease-in-out p-4 md:p-6"
  role="alert"
 data-ps="src/components/CookieBanner.astro:9aobia">
  <div class="max-w-7xl mx-auto" data-ps="src/components/CookieBanner.astro:9aobib">
    <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6" data-ps="src/components/CookieBanner.astro:9aobic">
      <div class="flex-1" data-ps="src/components/CookieBanner.astro:9aobid">
        <h2 class="text-xl font-bold text-gray-900 mb-2" data-ps="src/components/CookieBanner.astro:e20bdj">Cookie Settings</h2>
        <p class="text-gray-600 text-sm md:text-base leading-relaxed" data-ps="src/components/CookieBanner.astro:u7urzy">
          We use cookies to enhance your browsing experience and analyze our traffic. By clicking "Accept", you consent to our use of cookies. Read our 
          <a href="/cookie-policy/" class="text-primary hover:underline font-medium" style={`color: ${primaryColor}`} data-ps="src/components/CookieBanner.astro:tzljz5">Cookie Policy</a> to learn more.
      </div>
      
      <div class="flex flex-wrap items-center gap-4 w-full md:w-auto" data-ps="src/components/CookieBanner.astro:9aobie">
        <button
          id="cookie-reject"
          class="flex-1 md:flex-none px-8 py-3 rounded-full text-sm font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 transition-colors"
         data-ps="src/components/CookieBanner.astro:q73spn">
          Reject
        </button>
        <button
          id="cookie-accept"
          class="flex-1 md:flex-none px-8 py-3 rounded-full text-sm font-semibold text-gray-50 bg-gray-900 transition-all hover:opacity-90 active:scale-95"
          style={`background-color: ${primaryColor}`}
         data-ps="src/components/CookieBanner.astro:q73spm">
          Accept
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const rejectBtn = document.getElementById('cookie-reject');
    const CONSENT_KEY = 'cookie-consent';

    function setConsent(choice) {
      localStorage.setItem(CONSENT_KEY, choice);
      banner.classList.add('translate-y-full');
      
      if (choice === 'accepted') {
        window.dispatchEvent(new Event('cookie-consent-accepted'));
        // Reload if needed to trigger scripts that check on load
        // location.reload(); 
      }
    }

    const consent = localStorage.getItem(CONSENT_KEY);
    
    if (!consent) {
      // Show banner with delay for better UX
      setTimeout(() => {
        banner.classList.remove('translate-y-full');
      }, 1000);
    } else if (consent === 'accepted') {
      window.dispatchEvent(new Event('cookie-consent-accepted'));
    }

    acceptBtn.addEventListener('click', () => setConsent('accepted'));
    rejectBtn.addEventListener('click', () => setConsent('rejected'));
  })();
</script>
