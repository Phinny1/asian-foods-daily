---
import { siteConfig } from '../config/site';
import { getCollection } from 'astro:content';

const allRecipes = await getCollection('recipes');
const recentRecipes = allRecipes
  .filter(recipe => !recipe.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 3);
---

<footer class="bg-zinc-950 text-white py-24 border-t border-zinc-900" data-ps="src/components/Footer.astro:7iejvu">
  <div class="container mx-auto px-4" data-ps="src/components/Footer.astro:p4vf8b">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20" data-ps="src/components/Footer.astro:p4vf8a">
      <div class="col-span-1 lg:col-span-1" data-ps="src/components/Footer.astro:p4vf89">
        <a href="/" class="flex items-center mb-8 group" data-ps="src/components/Footer.astro:7gqbyt">
          <span class="text-xl font-black tracking-tighter" data-ps="src/components/Footer.astro:abywyv">AsianFoods<span class="text-red-400" data-ps="src/components/Footer.astro:abywyu">Daily</span></span>
        </a>
        <p class="text-zinc-400 leading-relaxed mb-8 max-w-sm" data-ps="src/components/Footer.astro:csf9x">
          Master the authentic flavors of Asia with our curated collection of traditional and modern recipes. Your daily guide to Asian culinary excellence.
        </p>
        <div class="flex gap-4" data-ps="src/components/Footer.astro:p4vf87">
          <a href="https://facebook.com/asianfoodsdaily" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-zinc-900 rounded-full flex items-center justify-center hover:bg-red-600 transition-colors" data-ps="src/components/Footer.astro:7gqbys">
            <span class="sr-only" data-ps="src/components/Footer.astro:abywy8">Facebook</span>
            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://instagram.com/asianfoodsdaily" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-zinc-900 rounded-full flex items-center justify-center hover:bg-red-600 transition-colors" data-ps="src/components/Footer.astro:7gqbyr">
            <span class="sr-only" data-ps="src/components/Footer.astro:abywy7">Instagram</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="https://pinterest.com/asianfoodsdaily" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-zinc-900 rounded-full flex items-center justify-center hover:bg-red-600 transition-colors" data-ps="src/components/Footer.astro:pin-1">
            <span class="sr-only" data-ps="src/components/Footer.astro:hzwfp9">Pinterest</span>
            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.966 1.406-5.966s-.359-.72-.359-1.781c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.261 7.929-7.261 4.164 0 7.398 2.967 7.398 6.93 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.622 0 11.988-5.365 11.988-11.986C24.005 5.368 18.639 0 12.017 0z"/></svg>
          </a>
        </div>
      </div>

      <div data-ps="src/components/Footer.astro:p4vf86">
        <h4 class="text-lg font-bold mb-8 text-white uppercase tracking-widest text-sm" data-ps="src/components/Footer.astro:2uqr9j">Cuisines</h4>
        <ul class="space-y-4 text-zinc-400">
          <li data-ps="src/components/Footer.astro:wyji4p"><a href="/cuisines/chinese/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbyq">Chinese Recipes</a></li>
          <li data-ps="src/components/Footer.astro:wyji4o"><a href="/cuisines/japanese/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbyp">Japanese Cuisine</a></li>
          <li data-ps="src/components/Footer.astro:wyji42"><a href="/cuisines/korean/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbyo">Korean Favorites</a></li>
          <li data-ps="src/components/Footer.astro:wyji41"><a href="/cuisines/thai/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbyn">Thai Specialties</a></li>
          <li data-ps="src/components/Footer.astro:wyji40"><a href="/cuisines/filipino/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqby1">Filipino Comfort Food</a></li>
          <li data-ps="src/components/Footer.astro:wyji-viet"><a href="/cuisines/vietnamese/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:viet-link">Vietnamese Delights</a></li>
          <li data-ps="src/components/Footer.astro:wyji-indian"><a href="/cuisines/indian/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:indian-link">Indian Flavors</a></li>
        </ul>
      </div>

      <div data-ps="src/components/Footer.astro:p4vf85">
        <h4 class="text-lg font-bold mb-8 text-white uppercase tracking-widest text-sm" data-ps="src/components/Footer.astro:2uqr9i">Quick Links</h4>
        <ul class="space-y-4 text-zinc-400">
          <li data-ps="src/components/Footer.astro:wyji3z"><a href="/recipes/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqby0">Browse Recipes</a></li>
          <li data-ps="src/components/Footer.astro:wyji3y"><a href="/about/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbxz">Our Story</a></li>
          <li data-ps="src/components/Footer.astro:wyji3x"><a href="/contact/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbxy">Contact Us</a></li>
          <li data-ps="src/components/Footer.astro:wyji3w"><a href="/privacy/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbxx">Privacy Policy</a></li>
          <li data-ps="src/components/Footer.astro:wyji3v"><a href="/terms/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbxw">Terms of Service</a></li>
          <li data-ps="src/components/Footer.astro:disclaimer-link"><a href="/disclaimer/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:7gqbxx-disc">Disclaimer</a></li>
          <li data-ps="src/components/Footer.astro:cookie-policy-link"><a href="/cookie-policy/" class="hover:text-red-500 transition-colors" data-ps="src/components/Footer.astro:cookie-link">Cookie Policy</a></li>
        </ul>
      </div>

      <div data-ps="src/components/Footer.astro:p4vf84">
        <h4 class="text-lg font-bold mb-8 text-white uppercase tracking-widest text-sm" data-ps="src/components/Footer.astro:2uqr9h">Recent Recipes</h4>
        <div class="space-y-6" data-ps="src/components/Footer.astro:p4vf83">
          {recentRecipes.map(recipe => (
            <a href={`/recipes/${recipe.slug}/`} class="flex gap-4 group" data-ps={`src/components/Footer.astro:recent-${recipe.slug}`}>
              <div class="w-16 h-16 rounded-lg overflow-hidden flex-shrink-0 bg-zinc-800" data-ps={`src/components/Footer.astro:img-${recipe.slug}`}>
                {recipe.data.image && (
                  <img src={recipe.data.image} alt={recipe.data.title} width="64" height="64" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" data-ps="src/components/Footer.astro:4qdjex" />
                )}
              </div>
              <div data-ps={`src/components/Footer.astro:txt-${recipe.slug}`}>
                <p class="text-sm font-bold leading-tight group-hover:text-red-500 transition-colors line-clamp-2" data-ps={`src/components/Footer.astro:title-${recipe.slug}`}>{recipe.data.title}</p>
                <p class="text-xs text-zinc-400 mt-1" data-ps={`src/components/Footer.astro:date-${recipe.slug}`}>
                  {recipe.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-zinc-900 flex flex-col md:flex-row justify-between items-center gap-8" data-ps="src/components/Footer.astro:256hn1">
      <p class="text-zinc-400 text-sm" data-ps="src/components/Footer.astro:csf9s">
        © {new Date().getFullYear()} Asian Foods Daily. All rights reserved.
      </p>
      <p class="text-zinc-400 text-sm flex items-center gap-2" data-ps="src/components/Footer.astro:csf9r">
        Made with <span class="text-red-400" data-ps="src/components/Footer.astro:abywy6">❤</span> for Asian Food Lovers
      </p>
    </div>
  </div>
</footer>
