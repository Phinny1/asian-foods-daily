---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { SITE } from '../config/site';
import Comments from '../components/Comments.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { RecipeSlider } from '../components/islands/RecipeSlider';
import { getCollection } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

const { frontmatter: frontmatterProp, mdxFilePath = '', headings = [], entry, ...props } = Astro.props as {
  frontmatter?: any;
  mdxFilePath?: string;
  headings?: Heading[];
  entry?: any;
  [key: string]: any;
};
const frontmatter = frontmatterProp || props;
const noindex = frontmatter.noindex || props.noindex || false;
const postSlug = Astro.url.pathname;

// Helper to ensure date is a Date object
const parseDate = (d: any) => {
  if (!d) return undefined;
  if (d instanceof Date) return d;
  const parsed = new Date(d);
  return isNaN(parsed.getTime()) ? undefined : parsed;
};
const pubDate = parseDate(frontmatter.pubDate);
const updatedDate = parseDate(frontmatter.updatedDate);

// Fetch recipes for the slider
const allRecipes = await getCollection('recipes');
const currentSlug = postSlug.split('/').filter(Boolean).pop();
const currentCategory = frontmatter.category?.toLowerCase();
const currentTags = Array.isArray(frontmatter.tags) ? frontmatter.tags.map((t: any) => String(t).toLowerCase()) : [];
const currentTitleWords = frontmatter.title ? frontmatter.title.toLowerCase().split(/\s+/).filter((w: string) => w.length > 3) : [];

const otherRecipes = allRecipes
  .filter(r => r.slug !== currentSlug) // Exclude current post
  .map(r => {
    let score = 0;
    const rData = r.data;
    const rCategory = rData.category?.toLowerCase();
    const rTags = Array.isArray(rData.tags) ? rData.tags.map((t: string) => t.toLowerCase()) : [];
    const rTitle = rData.title.toLowerCase();

    // 1. Category Match (Strong signal)
    if (currentCategory && rCategory === currentCategory) {
      score += 10;
    }

    // 2. Tag Overlap
    const sharedTags = rTags.filter((t: string) => currentTags.includes(t));
    score += sharedTags.length * 5;

    // 3. Title Keyword Match
    const matchesTitle = currentTitleWords.some((w: string) => rTitle.includes(w));
    if (matchesTitle) {
      score += 3;
    }

    return {
      title: rData.title,
      slug: r.slug,
      image: rData.image,
      category: rData.category,
      score
    };
  })
  .filter(r => r.score > 0) // Only relevant ones
  .sort((a, b) => b.score - a.score) // Sort by relevance
  .slice(0, 12); // Limit to top 12

// TOC: enabled by default (matches schema default), can be disabled with toc: false
const showToc = frontmatter.toc !== false && headings.length > 0;

// Use ogImage if set, otherwise fall back to featured image
const socialImage = frontmatter.ogImage || frontmatter.image;

// Build JSON-LD structured data based on schemaType or default to Article
const schemaType = frontmatter.schemaType || 'Article';
const schemaData = frontmatter.schemaData || {};

// Breadcrumb JSON-LD
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    {
      '@type': 'ListItem',
      'position': 1,
      'name': 'Home',
      'item': SITE.url
    },
    {
      '@type': 'ListItem',
      'position': 2,
      'name': 'Blog',
      'item': new URL('/blog/', SITE.url).toString()
    },
    {
      '@type': 'ListItem',
      'position': 3,
      'name': frontmatter.title,
      'item': new URL(Astro.url.pathname, SITE.url).toString()
    }
  ]
};

// Base JSON-LD structure
const jsonLd: any[] = [
  {
  '@context': 'https://schema.org',
  '@type': schemaType,
  headline: frontmatter.title,
  description: frontmatter.description,
  author: {
    '@type': 'Person',
    name: 'AsianFoodsDaily',
    url: SITE.url
  },
  datePublished: pubDate?.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate?.toISOString(),
  image: socialImage ? (socialImage.startsWith('http') ? socialImage : new URL(socialImage, SITE.url).toString()) : undefined,
  publisher: {
    '@type': 'Organization',
    name: 'Asian Foods Daily',
    logo: {
      '@type': 'ImageObject',
      url: 'https://cdn.pagesmith.app/97394d4a-9281-4e16-8125-5ce5d075881b/Thai-Cucumber-Shrimp-Salad-2-1536x857-1536.webp'
    }
  },
  keywords: frontmatter.tags ? (Array.isArray(frontmatter.tags) ? frontmatter.tags.join(', ') : frontmatter.tags) : undefined,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(Astro.url.pathname, SITE.url).toString()
  },
  url: new URL(Astro.url.pathname, SITE.url).toString(),
},
breadcrumbLd
];

// Merge custom schemaData for specific schema types
if (schemaType === 'Recipe' && schemaData) {
  // Recipe-specific fields
  if (schemaData.prepTime) jsonLd[0].prepTime = `PT${schemaData.prepTime.replace(/\s+/g, '').toUpperCase()}`;
  if (schemaData.cookTime) jsonLd[0].cookTime = `PT${schemaData.cookTime.replace(/\s+/g, '').toUpperCase()}`;
  if (schemaData.totalTime) jsonLd[0].totalTime = `PT${schemaData.totalTime.replace(/\s+/g, '').toUpperCase()}`;
  if (schemaData.servings) jsonLd[0].recipeYield = schemaData.servings;
  if (schemaData.cuisine) jsonLd[0].recipeCuisine = schemaData.cuisine;
  if (schemaData.category) jsonLd[0].recipeCategory = schemaData.category;
  if (schemaData.ingredients) jsonLd[0].recipeIngredient = schemaData.ingredients;
  if (schemaData.instructions) {
    jsonLd[0].recipeInstructions = Array.isArray(schemaData.instructions)
      ? schemaData.instructions.map((step: string, i: number) => ({
          '@type': 'HowToStep',
          position: i + 1,
          text: step,
        }))
      : schemaData.instructions;
  }
} else if (schemaType === 'HowTo' && schemaData) {
  // HowTo-specific fields
  if (schemaData.totalTime) jsonLd[0].totalTime = `PT${schemaData.totalTime.replace(/\s+/g, '').toUpperCase()}`;
  if (schemaData.steps) {
    jsonLd[0].step = schemaData.steps.map((step: string, i: number) => ({
      '@type': 'HowToStep',
      position: i + 1,
      text: step,
    }));
  }
} else if (schemaType === 'FAQ' && schemaData) {
  // FAQ-specific fields
  if (schemaData.questions) {
    jsonLd[0].mainEntity = schemaData.questions.map((q: { question: string; answer: string }) => ({
      '@type': 'Question',
      name: q.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: q.answer,
      },
    }));
  }
} else if (schemaType === 'Product' && schemaData) {
  // Product-specific fields
  if (schemaData.brand) jsonLd[0].brand = { '@type': 'Brand', name: schemaData.brand };
  if (schemaData.price) {
    jsonLd[0].offers = {
      '@type': 'Offer',
      price: schemaData.price,
      priceCurrency: schemaData.currency || 'USD',
      availability: schemaData.availability || 'https://schema.org/InStock',
    };
  }
} else if (schemaType === 'Event' && schemaData) {
  // Event-specific fields
  if (schemaData.startDate) jsonLd[0].startDate = schemaData.startDate;
  if (schemaData.endDate) jsonLd[0].endDate = schemaData.endDate;
  if (schemaData.location) {
    jsonLd[0].location = {
      '@type': 'Place',
      name: schemaData.location,
      address: schemaData.address,
    };
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"}>
    <SEOHead
      title={`${frontmatter.title} – ${SITE.name}`}
      description={frontmatter.description}
      image={socialImage}
      type="article"
      publishedTime={pubDate?.toISOString()}
      modifiedTime={updatedDate?.toISOString()}
      jsonLd={jsonLd}
    />
  </head>
  <body class="min-h-screen bg-white" style="color: var(--text);" data-ps="src/layouts/BlogLayout.astro:rqzn4e">
    <Navigation />

    <main class="pt-24 pb-20" data-ps="src/layouts/BlogLayout.astro:1pntf2">
      <article
        class="container mx-auto max-w-3xl px-6"
        data-mdx-file={mdxFilePath}
        data-mdx-type="blog"
        data-ps="src/layouts/BlogLayout.astro:xkhs7u">
        
        <header class="mb-12" data-ps="src/layouts/BlogLayout.astro:fqly23">
          <nav class="flex items-center gap-2 text-xs font-medium text-gray-500 mb-8 overflow-x-auto whitespace-nowrap scrollbar-hide" aria-label="Breadcrumb" data-ps="src/layouts/BlogLayout.astro:breadcrumb">
            <a href="/" class="hover:text-[#dc2626] transition-colors" data-ps="src/layouts/BlogLayout.astro:su3wl9">Home</a>
            <span class="text-gray-600" data-ps="src/layouts/BlogLayout.astro:dfgz5f">›</span>
            <a href="/blog/" class="hover:text-[#dc2626] transition-colors" data-ps="src/layouts/BlogLayout.astro:su3wl8">Blog</a>
            <span class="text-gray-600" data-ps="src/layouts/BlogLayout.astro:dfgz5e">›</span>
            <span class="text-gray-900 truncate" data-ps="src/layouts/BlogLayout.astro:dfgz5d">
              {frontmatter.title.length > 50 ? frontmatter.title.substring(0, 50) + '...' : frontmatter.title}
            </span>
          </nav>

          <div class="flex items-center gap-3 mb-6 text-sm font-bold uppercase tracking-widest text-cyan-700" data-ps="src/layouts/BlogLayout.astro:category-badge">
            {frontmatter.category}
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-zinc-900 mb-8 leading-[1.1]" data-ps="src/layouts/BlogLayout.astro:sihpnt">{frontmatter.title}</h1>

          {frontmatter.image && (
            <div class="mb-8 -mx-6 md:-mx-12 lg:-mx-24" data-ps="src/layouts/BlogLayout.astro:featured-image">
              <img
                src={frontmatter.image}
                alt={frontmatter.title}
                class="w-full h-auto rounded-3xl shadow-xl object-cover max-h-[500px]"
                loading="eager" data-ps="src/layouts/BlogLayout.astro:h2r8qr" />
            </div>
          )}

          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 text-gray-500 text-sm border-y border-gray-100 py-6" data-ps="src/layouts/BlogLayout.astro:o33ul5">
            <div class="flex items-center gap-3" data-ps="src/layouts/BlogLayout.astro:author-block">
              <span class="w-10 h-10 rounded-full bg-cyan-900 flex items-center justify-center text-cyan-50 font-bold text-sm shadow-sm" data-ps="src/layouts/BlogLayout.astro:author-avatar">
                A
              </span>
              <div class="flex flex-col" data-ps="src/layouts/BlogLayout.astro:author-info">
                <span class="text-black font-black text-base" data-ps="src/layouts/BlogLayout.astro:author-name">Asianfoodsdaily</span>
                {pubDate && (
                  <time datetime={pubDate.toISOString()} class="text-xs text-gray-600 uppercase font-bold tracking-tight">
                    {pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                )}
              </div>
            </div>
            <div class="flex items-center gap-4" data-ps="src/layouts/BlogLayout.astro:share-wrapper">
              <span class="text-[10px] font-black uppercase tracking-widest text-gray-600" data-ps="src/layouts/BlogLayout.astro:dfgz5e">Share:</span>
              <div class="flex items-center gap-4" data-ps="src/layouts/BlogLayout.astro:o33ul5">
                <ShareButtons title={frontmatter.title} url={new URL(Astro.url.pathname, SITE.url).toString()} />
              </div>
            </div>
          </div>
        </header>

        <div class="recipe-content prose prose-slate prose-lg md:prose-xl max-w-none prose-headings:text-zinc-900 prose-headings:font-black prose-p:text-gray-700 prose-p:leading-relaxed prose-li:text-gray-700 prose-strong:text-gray-900 prose-img:rounded-3xl prose-img:shadow-xl prose-a:text-[#dc2626] prose-a:font-bold hover:prose-a:underline" data-ps="src/layouts/BlogLayout.astro:o33ul6">
          <slot />
        </div>

        <script>
          // Fix external links that are missing protocol
          document.addEventListener('DOMContentLoaded', () => {
            const articleContent = document.querySelector('.recipe-content');
            if (!articleContent) return;

            const links = articleContent.querySelectorAll('a');
            links.forEach(link => {
              const href = link.getAttribute('href');
              if (!href) return;

              // Check if it's an external-looking link but treated as relative
              // e.g. "www.google.com" or "google.com" but not starting with / or # or http
              if (!href.startsWith('/') && !href.startsWith('#') && !href.startsWith('http') && !href.startsWith('mailto:')) {
                // It's likely a domain without protocol
                link.setAttribute('href', 'https://' + href);
                link.setAttribute('target', '_blank');
                link.setAttribute('rel', 'noopener noreferrer');
              }
              
              // Also catch links that are already http/https but missing target=_blank
              if (href.startsWith('http') && !href.includes(window.location.hostname)) {
                link.setAttribute('target', '_blank');
                link.setAttribute('rel', 'noopener noreferrer');
              }
            });
          });
        </script>

        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <footer class="mt-16 pt-10 border-t border-gray-100" data-ps="src/layouts/BlogLayout.astro:fydg8a">
            <div class="flex flex-wrap gap-2" data-ps="src/layouts/BlogLayout.astro:dfgz5m-container">
              {frontmatter.tags.map((tag: any) => (
                <span class="bg-gray-50 text-gray-600 px-4 py-1.5 rounded-full text-sm font-medium hover:bg-cyan-900 hover:text-cyan-50 transition-all cursor-default" data-ps="src/layouts/BlogLayout.astro:dfgz5m">
                  #{tag}
                </span>
              ))}
            </div>
          </footer>
        )}

        <div class="mt-16" data-ps="src/layouts/BlogLayout.astro:recipe-slider-wrapper">
          <RecipeSlider title="Recipes to Try" recipes={otherRecipes} client:visible />
        </div>

        <div class="mt-12" data-ps="src/layouts/BlogLayout.astro:comments-wrapper">
          <Comments slug={postSlug} />
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>
